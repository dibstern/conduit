				{
					"type": "user_message",
					"text": "Write a paragraph explaining why automated testing is important for software quality."
				},
				{
					"type": "result",
					"usage": {
						"input": 0,
						"output": 0,
						"cache_read": 0,
						"cache_creation": 0
					},
